<% layout("/layouts/boilerplate") %>
    <style>
        .listing-link {
            text-decoration: none;
            color: black;
        }

        .listing-card {
            transition: transform 0.2s ease-in-out;
        }

        .listing-card:hover {
            opacity: 0.8;
        }

        #filters {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: center;
        }

        .filter {
            text-decoration: none;
            color: black;
            text-align: center;
            margin-top: 1rem;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            background-color: #f0f0f0;
            transition: background-color 0.2s ease-in-out;
            opacity: 0.8;
            flex-shrink: 0;
        }

        .filter:hover {
            background-color: #e0e0e0;
            cursor: pointer;
            opacity: 1;
        }

        .filter p {
            margin: 0;
            font-size: 0.8rem;
        }

        .tax-toggle {
            display: flex;
            align-items: center;
            height: 3.25rem;
            border: 1px solid #ccc;
            border-radius: 1rem;
            padding: 0.5rem 1rem;
        }

        .mobile-tax {
            display: none;
        }

        .tax-info {
            display: none;
            font-size: 0.7rem;
            color: gray;
        }

        /* MOBILE */
        @media (max-width: 768px) {
            #filters {
                flex-wrap: nowrap;
                overflow-x: auto;
                overflow-y: hidden;
                white-space: nowrap;
                padding-bottom: 0.5rem;
                scrollbar-width: none;
            }

            #filters::-webkit-scrollbar {
                display: none;
            }

            .filter {
                min-width: fit-content;
                margin-top: 0.5rem;
            }

            .desktop-tax {
                display: none;
            }

            .mobile-tax {
                display: flex;
                width: fit-content;
                margin: 1rem auto 0 auto;
            }
        }
    </style>
    <div id="filters">
        <a class="filter" href="/listings?category=Trending">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </a>
        <a class="filter" href="/listings?category=Rooms">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </a>
        <a class="filter" href="/listings?category=Iconic_cities">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic cities</p>
        </a>
        <a class="filter" href="/listings?category=Mountains">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </a>
        <a class="filter" href="/listings?category=Castels">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castels</p>
        </a>
        <a class="filter" href="/listings?category=Amazing_pools">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing pools</p>
        </a>
        <a class="filter" href="/listings?category=Camping">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </a>
        <a class="filter" href="/listings?category=Farms">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </a>
        <a class="filter" href="/listings?category=Arctic">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </a>
        <div class="tax-toggle desktop-tax">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input tax-switch" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>
    <div class="tax-toggle mobile-tax">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input tax-switch" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
        <% for (let listing of allListings) { %>
            <a href="/listings/<%=listing._id %>" class="listing-link">
                <div class="card listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                        style="height: 20rem" />
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b>
                                <%= listing.title %>
                            </b> <br />
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                                <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
            <% } %>
    </div>

    <script>
        let taxSwitch = document.querySelectorAll(".tax-switch");
        taxSwitch.forEach((toggle) => {
            toggle.addEventListener("change", () => {
                let taxInfo = document.getElementsByClassName("tax-info");
                taxSwitch.forEach(sw => sw.checked = toggle.checked);
                for (let info of taxInfo) {
                    info.style.display = toggle.checked ? "inline" : "none"
                }
            })
        })
    </script>